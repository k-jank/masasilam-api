<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.masasilam.app.mapper.ZineReviewReplyMapper">

    <resultMap id="ZineReviewReplyResultMap" type="com.masasilam.app.model.entity.ZineReviewReply">
        <id     property="id"            column="id"/>
        <result property="userId"        column="user_id"/>
        <result property="reviewId"      column="review_id"/>
        <result property="parentReplyId" column="parent_reply_id"/>
        <result property="content"       column="content"/>
        <result property="isDeleted"     column="is_deleted"/>
        <result property="createdAt"     column="created_at"/>
        <result property="updatedAt"     column="updated_at"/>
    </resultMap>

    <!-- ── INSERT ──────────────────────────────────────────────────────────── -->

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO zine_review_replies (
        user_id, review_id, parent_reply_id,
        content, is_deleted, created_at, updated_at
        ) VALUES (
        #{userId}, #{reviewId}, #{parentReplyId},
        #{content}, false, #{createdAt}, #{updatedAt}
        )
    </insert>

    <!-- ── UPDATE ──────────────────────────────────────────────────────────── -->

    <update id="update">
        UPDATE zine_review_replies
        SET content    = #{content},
        updated_at = #{updatedAt}
        WHERE id = #{id}
        AND is_deleted = false
    </update>

    <!-- ── SOFT DELETE ─────────────────────────────────────────────────────── -->

    <update id="softDelete">
        UPDATE zine_review_replies
        SET is_deleted = true,
        updated_at = NOW()
        WHERE id = #{id}
    </update>

    <!-- ── FIND BY ID ──────────────────────────────────────────────────────── -->

    <select id="findById" resultMap="ZineReviewReplyResultMap">
        SELECT * FROM zine_review_replies
        WHERE id = #{id}
        AND is_deleted = false
    </select>

    <!-- ── FIND BY REVIEW ID ───────────────────────────────────────────────── -->

    <select id="findByReviewId" resultMap="ZineReviewReplyResultMap">
        SELECT * FROM zine_review_replies
        WHERE review_id = #{reviewId}
        AND is_deleted = false
        ORDER BY created_at ASC
    </select>

</mapper>