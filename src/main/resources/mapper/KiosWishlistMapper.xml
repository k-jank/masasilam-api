<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.masasilam.app.mapper.kios.KiosWishlistMapper">
    <insert id="insertWishlist" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO wishlists (user_id, product_id, created_at)
        VALUES (#{userId}, #{productId}, #{createdAt})
    </insert>

    <delete id="deleteWishlist">
        DELETE FROM wishlists
        WHERE id = #{id}
    </delete>

    <select id="findByUserId" resultType="com.masasilam.app.model.entity.Wishlist">
        SELECT *
        FROM wishlists
        WHERE user_id = #{userId}
    </select>

    <select id="findByUserAndProduct" resultType="com.masasilam.app.model.entity.Wishlist">
        SELECT *
        FROM wishlists
        WHERE user_id = #{userId}
        AND product_id = #{productId}
    </select>
</mapper>