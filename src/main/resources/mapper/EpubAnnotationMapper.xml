<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.naskah.demo.mapper.EpubAnnotationMapper">

    <resultMap id="EpubAnnotationRM" type="com.naskah.demo.model.entity.EpubAnnotation">
        <id     property="id"           column="id"/>
        <result property="userId"       column="user_id"/>
        <result property="bookId"       column="book_id"/>
        <result property="cfi"          column="cfi"/>
        <result property="selectedText" column="selected_text"/>
        <result property="color"        column="color"/>
        <result property="note"         column="note"/>
        <result property="createdAt"    column="created_at"/>
        <result property="updatedAt"    column="updated_at"/>
    </resultMap>

    <!-- ─── SELECT ─────────────────────────────────────────────────────────── -->

    <select id="findByUserAndBook" resultMap="EpubAnnotationRM">
        SELECT id, user_id, book_id, cfi, selected_text, color, note,
        created_at, updated_at
        FROM epub_annotations
        WHERE user_id = #{userId}
        AND book_id = #{bookId}
        ORDER BY created_at DESC
    </select>

    <select id="findById" resultMap="EpubAnnotationRM">
        SELECT id, user_id, book_id, cfi, selected_text, color, note,
        created_at, updated_at
        FROM epub_annotations
        WHERE id = #{id}
    </select>

    <!-- ─── INSERT ─────────────────────────────────────────────────────────── -->

    <!--
        useGeneratedKeys + keyProperty memastikan id yang di-generate DB
        langsung di-set ke dalam objek EpubAnnotation setelah insert.
        Frontend butuh id ini untuk operasi delete selanjutnya.
    -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO epub_annotations
        (user_id, book_id, cfi, selected_text, color, note, created_at, updated_at)
        VALUES (#{userId}, #{bookId}, #{cfi}, #{selectedText},
        #{color}, #{note}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- ─── DELETE ─────────────────────────────────────────────────────────── -->

    <delete id="deleteById">
        DELETE FROM epub_annotations
        WHERE id = #{id}
    </delete>

</mapper>