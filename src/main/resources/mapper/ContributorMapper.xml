<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.masasilam.app.mapper.ContributorMapper">

    <resultMap id="ContributorResultMap" type="com.masasilam.app.model.entity.Contributor">
        <id   property="id"         column="id"/>
        <result property="name"       column="name"/>
        <result property="slug"       column="slug"/>
        <result property="role"       column="role"/>
        <result property="websiteUrl" column="website_url"/>
        <result property="createdAt"  column="created_at"/>
        <result property="updatedAt"  column="updated_at"/>
        <!-- field virtual dari COUNT JOIN, tidak selalu ada -->
        <result property="totalBooks" column="total_books"/>
    </resultMap>

    <!-- ═══════════════════════════════════════════════════
         FIND BY NAME AND ROLE
         Dipakai saat import epub — cegah duplikat contributor
         dengan kombinasi nama + role yang sama
    ═══════════════════════════════════════════════════ -->
    <select id="findByNameAndRole" resultMap="ContributorResultMap">
        SELECT *
        FROM contributors
        WHERE LOWER(name) = LOWER(#{name})
        AND LOWER(role) = LOWER(#{role})
        LIMIT 1
    </select>

    <!-- ═══════════════════════════════════════════════════
         FIND BY NAME (tanpa role)
         Dipakai EpubRebuildService untuk cek editor existing
    ═══════════════════════════════════════════════════ -->
    <select id="findByName" resultMap="ContributorResultMap">
        SELECT *
        FROM contributors
        WHERE LOWER(name) = LOWER(#{name})
        LIMIT 1
    </select>

    <!-- ═══════════════════════════════════════════════════
         FIND BY SLUG
    ═══════════════════════════════════════════════════ -->
    <select id="findBySlug" resultMap="ContributorResultMap">
        SELECT *
        FROM contributors
        WHERE slug = #{slug}
        LIMIT 1
    </select>

    <!-- ═══════════════════════════════════════════════════
         INSERT CONTRIBUTOR
    ═══════════════════════════════════════════════════ -->
    <insert id="insertContributor"
            parameterType="com.masasilam.app.model.entity.Contributor"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO contributors (name, slug, role, created_at, updated_at)
        VALUES (#{name}, #{slug}, #{role}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- ═══════════════════════════════════════════════════
         FIND ALL WITH PAGINATION + FILTER
         Termasuk total_books dari JOIN ke book_contributors
    ═══════════════════════════════════════════════════ -->
    <select id="findAllWithPagination" resultMap="ContributorResultMap">
        SELECT
        c.*,
        COUNT(bc.book_id) AS total_books
        FROM contributors c
        LEFT JOIN book_contributors bc ON c.id = bc.contributor_id
        <where>
            <if test="role != null and role != ''">
                AND c.role = #{role}
            </if>
            <if test="search != null and search != ''">
                AND c.name LIKE CONCAT('%', #{search}, '%')
            </if>
        </where>
        GROUP BY c.id
        ORDER BY c.name ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- ═══════════════════════════════════════════════════
         COUNT ALL (untuk pagination)
    ═══════════════════════════════════════════════════ -->
    <select id="countAll" resultType="int">
        SELECT COUNT(*)
        FROM contributors
        <where>
            <if test="role != null and role != ''">
                role = #{role}
            </if>
            <if test="search != null and search != ''">
                AND name LIKE CONCAT('%', #{search}, '%')
            </if>
        </where>
    </select>

    <!-- ═══════════════════════════════════════════════════
         COUNT BOOK CONTRIBUTOR
         Cek apakah relasi book-contributor sudah ada
    ═══════════════════════════════════════════════════ -->
    <select id="countBookContributor" resultType="int">
        SELECT COUNT(*)
        FROM book_contributors
        WHERE book_id        = #{bookId}
        AND contributor_id = #{contributorId}
        AND role           = #{role}
    </select>

    <!-- ═══════════════════════════════════════════════════
         INSERT BOOK CONTRIBUTOR
         ON CONFLICT DO NOTHING → aman dipanggil berkali-kali
    ═══════════════════════════════════════════════════ -->
    <insert id="insertBookContributor">
        INSERT INTO book_contributors (book_id, contributor_id, role)
        VALUES (#{bookId}, #{contributorId}, #{role})
        ON CONFLICT (book_id, contributor_id, role) DO NOTHING
    </insert>

</mapper>