<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.masasilam.app.mapper.kios.KiosCartMapper">
    <insert id="insertCartItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO cart_items (user_id, product_id, quantity, created_at, updated_at)
        VALUES (#{userId}, #{productId}, #{quantity}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="updateCartItem">
        UPDATE cart_items
        SET quantity = #{quantity},
        updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="deleteCartItem">
        DELETE FROM cart_items
        WHERE id = #{id}
    </delete>

    <delete id="deleteAllByUserId">
        DELETE FROM cart_items
        WHERE user_id = #{userId}
    </delete>

    <select id="findCartItemById" resultType="com.masasilam.app.model.entity.CartItem">
        SELECT *
        FROM cart_items
        WHERE id = #{id}
    </select>

    <select id="findByUserId" resultType="com.masasilam.app.model.entity.CartItem">
        SELECT *
        FROM cart_items
        WHERE user_id = #{userId}
    </select>

    <select id="findByUserAndProduct" resultType="com.masasilam.app.model.entity.CartItem">
        SELECT *
        FROM cart_items
        WHERE user_id = #{userId}
        AND product_id = #{productId}
    </select>
</mapper>