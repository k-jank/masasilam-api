<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.masasilam.app.mapper.author.AuthorMapper">
    <select id="findAuthorByName" resultType="com.masasilam.app.model.entity.Author">
        SELECT *
        FROM authors
        WHERE name = #{name}
    </select>

    <select id="findAuthorBySlug" resultType="com.masasilam.app.model.entity.Author">
        SELECT *
        FROM authors
        WHERE slug = #{slug}
    </select>

    <select id="findAllAuthors" resultType="com.masasilam.app.model.entity.Author">
        SELECT id, name, slug, updated_at, created_at
        FROM authors
        WHERE id IN (SELECT DISTINCT author_id FROM book_authors)
        ORDER BY name ASC
    </select>

    <select id="findAllWithPagination" resultType="com.masasilam.app.model.entity.Author">
        SELECT *
        FROM authors
        <where>
            <if test="search != null and search != ''">
                name LIKE CONCAT('%', #{search}, '%')
            </if>
        </where>
        ORDER BY ${sortColumn} ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*)
        FROM authors
        <where>
            <if test="search != null and search != ''">
                name LIKE CONCAT('%', #{search}, '%')
            </if>
        </where>
    </select>

    <select id="findAuthorsByBookId" resultType="com.masasilam.app.model.dto.response.AuthorResponse">
        SELECT a.id,
        a.name,
        a.slug,
        a.birth_date,
        a.death_date,
        a.birth_place,
        a.nationality,
        a.photo_url
        FROM authors a
        INNER JOIN book_authors ba ON a.id = ba.author_id
        WHERE ba.book_id = #{bookId}
    </select>

    <insert id="insertAuthor" parameterType="com.masasilam.app.model.entity.Author" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO authors
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="slug != null">slug,</if>
            <if test="birthDate != null">birth_date,</if>
            <if test="deathDate != null">death_date,</if>
            <if test="birthPlace != null">birth_place,</if>
            <if test="nationality != null">nationality,</if>
            <if test="biography != null">biography,</if>
            <if test="photoUrl != null">photo_url,</if>
            <if test="photoPath != null">photo_path,</if>
            <if test="totalBooks != null">total_books,</if>
            created_at,
            updated_at,
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="slug != null">#{slug},</if>
            <if test="birthDate != null">#{birthDate},</if>
            <if test="deathDate != null">#{deathDate},</if>
            <if test="birthPlace != null">#{birthPlace},</if>
            <if test="nationality != null">#{nationality},</if>
            <if test="biography != null">#{biography},</if>
            <if test="photoUrl != null">#{photoUrl},</if>
            <if test="photoPath != null">#{photoPath},</if>
            <if test="totalBooks != null">#{totalBooks},</if>
            #{createdAt},
            #{updatedAt},
        </trim>
    </insert>

    <update id="updateAuthor" parameterType="com.masasilam.app.model.entity.Author">
        UPDATE authors
        <set>
            <trim suffixOverrides=",">
                <if test="name != null">name = #{name},</if>
                <if test="slug != null">slug = #{slug},</if>
                <if test="birthDate != null">birth_date = #{birthDate},</if>
                <if test="deathDate != null">death_date = #{deathDate},</if>
                <if test="birthPlace != null">birth_place = #{birthPlace},</if>
                <if test="nationality != null">nationality = #{nationality},</if>
                <if test="biography != null">biography = #{biography},</if>
                <if test="photoUrl != null">photo_url = #{photoUrl},</if>
                <if test="totalBooks != null">total_books = #{totalBooks},</if>
                updated_at = #{updatedAt},
            </trim>
        </set>
        WHERE id = #{id}
    </update>
</mapper>